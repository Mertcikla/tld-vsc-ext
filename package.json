{
  "name": "tldiagram",
  "displayName": "tlDiagram",
  "description": "Browse and edit tlDiagram architecture diagrams from VS Code",
  "version": "0.1.4",
  "publisher": "tlDiagram-com",
  "repository": "https://github.com/Mertcikla/tld-vsc-ext",
  "icon": "resources/logo-1024.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization"
  ],
  "tags": [
    "architecture",
    "diagram",
    "tlDiagram",
    "software design",
    "flow chart"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onUri"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tldiagram",
          "title": "tlDiagram",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "tldiagram": [
        {
          "id": "tldiagram.diagramTree",
          "name": "Diagrams"
        },
        {
          "id": "tldiagram.elementLibrary",
          "name": "Element Library"
        },
        {
          "id": "tldiagram.watchDiff",
          "name": "Watch Changes",
          "when": "tldiagram.mode == local"
        }
      ]
    },
    "commands": [
      {
        "command": "tldiagram.login",
        "title": "tlDiagram: Connect / Login",
        "enablement": "tldiagram.cloudEnabled"
      },
      {
        "command": "tldiagram.logout",
        "title": "tlDiagram: Disconnect",
        "enablement": "tldiagram.cloudEnabled"
      },
      {
        "command": "tldiagram.refresh",
        "title": "tlDiagram: Refresh Diagrams",
        "icon": "$(refresh)"
      },
      {
        "command": "tldiagram.openDiagram",
        "title": "Open Diagram",
        "icon": "$(open-preview)"
      },
      {
        "command": "tldiagram.createDiagram",
        "title": "tlDiagram: New Diagram",
        "icon": "$(add)"
      },
      {
        "command": "tldiagram.renameDiagram",
        "title": "Rename Diagram"
      },
      {
        "command": "tldiagram.deleteDiagram",
        "title": "Delete Diagram",
        "icon": "$(trash)"
      },
      {
        "command": "tldiagram.openInBrowser",
        "title": "Open in Browser",
        "icon": "$(link-external)"
      },
      {
        "command": "tldiagram.addElementToDiagram",
        "title": "Add to Diagram",
        "icon": "$(add)"
      },
      {
        "command": "tldiagram.goToDiagram",
        "title": "Go to Diagram"
      },
      {
        "command": "tldiagram.showLogs",
        "title": "tlDiagram: Show Logs"
      },
      {
        "command": "tldiagram.analyzeFolder",
        "title": "tlDiagram: Analyze Folder",
        "icon": "$(search)"
      },
      {
        "command": "tldiagram.switchMode",
        "title": "tlDiagram: Switch Mode (Local/Cloud)"
      },
      {
        "command": "tldiagram.startWatch",
        "title": "tlDiagram: Start Watching",
        "icon": "$(eye)"
      },
      {
        "command": "tldiagram.stopWatch",
        "title": "tlDiagram: Stop Watching",
        "icon": "$(circle-slash)"
      },
      {
        "command": "tldiagram.showWatchDiff",
        "title": "tlDiagram: Show Watch Changes",
        "icon": "$(diff)"
      },
      {
        "command": "tldiagram.watchQuickActions",
        "title": "tlDiagram: Watch Quick Actions"
      },
      {
        "command": "tldiagram.exportToCloud",
        "title": "tlDiagram: Upload Workspace to Cloud",
        "icon": "$(cloud-upload)",
        "enablement": "tldiagram.cloudEnabled"
      },
      {
        "command": "tldiagram.importFromCloud",
        "title": "tlDiagram: Download from Cloud",
        "icon": "$(cloud-download)",
        "enablement": "tldiagram.cloudEnabled"
      },
      {
        "command": "tldiagram.showSyncStatus",
        "title": "tlDiagram: Show Sync Status",
        "enablement": "tldiagram.cloudEnabled"
      },
      {
        "command": "tldiagram.diffWithCloud",
        "title": "tlDiagram: Compare with Cloud",
        "icon": "$(git-compare)",
        "enablement": "tldiagram.cloudEnabled"
      },
      {
        "command": "tldiagram.updateCli",
        "title": "tlDiagram: Update CLI"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "tldiagram.login",
          "when": "tldiagram.cloudEnabled"
        },
        {
          "command": "tldiagram.logout",
          "when": "tldiagram.cloudEnabled"
        },
        {
          "command": "tldiagram.exportToCloud",
          "when": "tldiagram.cloudEnabled"
        },
        {
          "command": "tldiagram.importFromCloud",
          "when": "tldiagram.cloudEnabled"
        },
        {
          "command": "tldiagram.showSyncStatus",
          "when": "tldiagram.cloudEnabled"
        },
        {
          "command": "tldiagram.diffWithCloud",
          "when": "tldiagram.cloudEnabled"
        }
      ],
      "editor/context": [
        {
          "command": "tldiagram.goToDiagram",
          "when": "tldiagram.authenticated && tldiagram.mode == local",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "tldiagram.goToDiagram",
          "when": "tldiagram.authenticated && tldiagram.mode == local",
          "group": "navigation"
        },
        {
          "command": "tldiagram.analyzeFolder",
          "when": "explorerResourceIsFolder",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "tldiagram.refresh",
          "when": "view == tldiagram.diagramTree && tldiagram.authenticated",
          "group": "navigation"
        },
        {
          "command": "tldiagram.createDiagram",
          "when": "view == tldiagram.diagramTree && tldiagram.authenticated",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "tldiagram.openDiagram",
          "when": "viewItem == diagram",
          "group": "inline"
        },
        {
          "command": "tldiagram.openInBrowser",
          "when": "viewItem == diagram",
          "group": "inline"
        },
        {
          "command": "tldiagram.renameDiagram",
          "when": "viewItem == diagram",
          "group": "1_modify"
        },
        {
          "command": "tldiagram.deleteDiagram",
          "when": "viewItem == diagram",
          "group": "1_modify"
        },
        {
          "command": "tldiagram.addElementToDiagram",
          "when": "viewItem == diagElement",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "tlDiagram",
      "properties": {
        "tldiagram.mode": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "local",
            "cloud"
          ],
          "enumDescriptions": [
            "Prefer local CLI if found, fall back to cloud",
            "Always use local mode (requires tld CLI)",
            "Always use cloud mode (requires login)"
          ],
          "description": "Connection mode for the tlDiagram extension"
        },
        "tldiagram.cliPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to the tld binary (empty = auto-detect on PATH)"
        },
        "tldiagram.autoStartWatch": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start tld watch when opening a workspace with .tld/ directory"
        },
        "tldiagram.cloud.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable cloud login and sync features. Disabled by default while the extension focuses on local tld workflows."
        },
        "tldiagram.serverUrl": {
          "type": "string",
          "default": "https://tldiagram.com",
          "description": "Base URL of your tlDiagram server (change only for self-hosted instances)"
        },
        "tldiagram.watch.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Host for the local watch/serve server"
        },
        "tldiagram.watch.port": {
          "type": "integer",
          "default": 0,
          "description": "Port for the local watch/serve server (0 = auto-select free port)"
        },
        "tldiagram.logLevel": {
          "type": "string",
          "default": "info",
          "enum": [
            "off",
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ],
          "enumDescriptions": [
            "No logging",
            "Errors only",
            "Errors and warnings",
            "Normal operational messages (default)",
            "Verbose: includes API calls, panel lifecycle, tree view updates",
            "Very verbose: includes every message routed through the bridge and every object created"
          ],
          "description": "Controls verbosity of the tlDiagram output channel. Use 'debug' or 'trace' when reporting issues."
        }
      }
    }
  },
  "scripts": {
    "compile:ext": "node esbuild.mjs",
    "compile:webview": "cd ../frontend-wrapper && npm run build:vscode",
    "compile": "npm run compile:ext && npm run compile:webview",
    "watch": "node esbuild.mjs --watch",
    "package": "npm run compile && npx @vscode/vsce package",
    "vscode:prepublish": "npm run compile",
    "test": "vitest run"
  },
  "dependencies": {
    "@buf/tldiagramcom_diagram.bufbuild_es": "^2.12.0-20260510134954-1dd1981cf3f6.1",
    "@bufbuild/protobuf": "^2.11.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-web": "^2.1.1"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "esbuild": "^0.25.0",
    "glob": "^13.0.6",
    "module-alias": "^2.3.4",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  }
}
