{
  "name": "tldiagram",
  "displayName": "tlDiagram",
  "description": "Browse and edit tlDiagram architecture diagrams from VS Code",
  "version": "0.1.0",
  "publisher": "tldiagramcom",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onUri"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tldiagram",
          "title": "tlDiagram",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "tldiagram": [
        {
          "id": "tldiagram.diagramTree",
          "name": "Diagrams"
        },
        {
          "id": "tldiagram.objectLibrary",
          "name": "Object Library"
        },
        {
          "id": "tldiagram.diagramObjects",
          "name": "Diagram Objects"
        }
      ]
    },
    "commands": [
      {
        "command": "tldiagram.login",
        "title": "tlDiagram: Connect / Login"
      },
      {
        "command": "tldiagram.logout",
        "title": "tlDiagram: Disconnect"
      },
      {
        "command": "tldiagram.refresh",
        "title": "tlDiagram: Refresh Diagrams",
        "icon": "$(refresh)"
      },
      {
        "command": "tldiagram.openDiagram",
        "title": "Open Diagram",
        "icon": "$(open-preview)"
      },
      {
        "command": "tldiagram.createDiagram",
        "title": "tlDiagram: New Diagram",
        "icon": "$(add)"
      },
      {
        "command": "tldiagram.renameDiagram",
        "title": "Rename Diagram"
      },
      {
        "command": "tldiagram.deleteDiagram",
        "title": "Delete Diagram",
        "icon": "$(trash)"
      },
      {
        "command": "tldiagram.openInBrowser",
        "title": "Open in Browser",
        "icon": "$(link-external)"
      },
      {
        "command": "tldiagram.exportDiagram",
        "title": "tlDiagram: Export Diagram"
      },
      {
        "command": "tldiagram.importDiagram",
        "title": "tlDiagram: Import Diagram"
      },
      {
        "command": "tldiagram.addObjectToDiagram",
        "title": "Add to Diagram",
        "icon": "$(add)"
      },
      {
        "command": "tldiagram.focusObject",
        "title": "Focus on Canvas"
      },
      {
        "command": "tldiagram.diagramCallGraph",
        "title": "tlDiagram: Diagram Call Graph",
        "icon": "$(type-hierarchy-sub)"
      },
      {
        "command": "tldiagram.diagramTypeHierarchy",
        "title": "tlDiagram: Diagram Type Hierarchy",
        "icon": "$(type-hierarchy)"
      },
      {
        "command": "tldiagram.showLogs",
        "title": "tlDiagram: Show Logs"
      },
      {
        "command": "tldiagram.generateArchitectureDiagram",
        "title": "tlDiagram: Generate Architecture Diagram",
        "icon": "$(symbol-structure)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "tldiagram.refresh",
          "when": "view == tldiagram.diagramTree && tldiagram.authenticated",
          "group": "navigation"
        },
        {
          "command": "tldiagram.createDiagram",
          "when": "view == tldiagram.diagramTree && tldiagram.authenticated",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "tldiagram.openDiagram",
          "when": "viewItem == diagram",
          "group": "inline"
        },
        {
          "command": "tldiagram.openInBrowser",
          "when": "viewItem == diagram",
          "group": "inline"
        },
        {
          "command": "tldiagram.renameDiagram",
          "when": "viewItem == diagram",
          "group": "1_modify"
        },
        {
          "command": "tldiagram.deleteDiagram",
          "when": "viewItem == diagram",
          "group": "1_modify"
        },
        {
          "command": "tldiagram.addObjectToDiagram",
          "when": "viewItem == diagObject",
          "group": "inline"
        }
      ],
      "explorer/context": [
        {
          "command": "tldiagram.generateArchitectureDiagram",
          "when": "explorerResourceIsFolder && tldiagram.authenticated",
          "group": "tldiagram@1"
        }
      ],
      "editor/context": [
        {
          "command": "tldiagram.diagramCallGraph",
          "when": "editorTextFocus && tldiagram.authenticated",
          "group": "tldiagram@1"
        },
        {
          "command": "tldiagram.diagramTypeHierarchy",
          "when": "editorTextFocus && tldiagram.authenticated",
          "group": "tldiagram@2"
        }
      ]
    },
    "configuration": {
      "title": "tlDiagram",
      "properties": {
        "tldiagram.serverUrl": {
          "type": "string",
          "default": "https://tldiagram.com",
          "description": "Base URL of your tlDiagram server (change only for self-hosted instances)"
        },
        "tldiagram.logLevel": {
          "type": "string",
          "default": "info",
          "enum": [
            "off",
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ],
          "enumDescriptions": [
            "No logging",
            "Errors only",
            "Errors and warnings",
            "Normal operational messages (default)",
            "Verbose: includes API calls, panel lifecycle, tree view updates",
            "Very verbose: includes every message routed through the bridge and every object created"
          ],
          "description": "Controls verbosity of the tlDiagram output channel. Use 'debug' or 'trace' when reporting issues."
        },
        "tldiagram.respectWorkspaceExcludes": {
          "type": "boolean",
          "default": true,
          "description": "When scanning for symbols, respect VS Code's files.exclude, search.exclude settings and .gitignore. When false, only built-in exclusions (node_modules, dist, build, out, .git) apply."
        },
        "tldiagram.extraExcludes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional glob patterns to exclude from symbol scanning. Example: [\"**/generated/**\", \"**/__mocks__/**\"]"
        },
        "tldiagram.callHierarchyMaxDepth": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "Maximum depth when building call graph or type hierarchy diagrams."
        },
        "tldiagram.architecture.abstractionLevel": {
          "type": "string",
          "default": "standard",
          "enum": [
            "overview",
            "standard",
            "detailed"
          ],
          "enumDescriptions": [
            "Score-based overview: 5-10 diagrams, 20-50 objects, 30-75 edges",
            "Score-based standard view: 10-25 diagrams, 40-100 objects, 60-150 edges",
            "Score-based detailed view: 25-40 diagrams, 100-500 objects, 150-750 edges"
          ],
          "description": "Default score profile for architecture diagram generation. It adjusts ranking targets, not parsing or scan depth, and can be overridden per-run via the quick pick."
        },
        "tldiagram.architecture.abstractionTargets": {
          "type": "object",
          "default": {
            "overview": {
              "diagrams": {
                "min": 5,
                "max": 10
              },
              "objects": {
                "min": 20,
                "max": 50
              },
              "edges": {
                "min": 30,
                "max": 75
              }
            },
            "standard": {
              "diagrams": {
                "min": 10,
                "max": 25
              },
              "objects": {
                "min": 40,
                "max": 100
              },
              "edges": {
                "min": 60,
                "max": 150
              }
            },
            "detailed": {
              "diagrams": {
                "min": 25,
                "max": 40
              },
              "objects": {
                "min": 100,
                "max": 500
              },
              "edges": {
                "min": 150,
                "max": 750
              }
            }
          },
          "description": "Optional per-level override for the abstraction score targets. Each min/max range is clamped in code to stay within 2x of the built-in baseline for that level."
        },
        "tldiagram.architecture.parserMode": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "lsp",
            "treesitter"
          ],
          "enumDescriptions": [
            "Prefer LSP symbol providers, then fall back to Tree-sitter if needed",
            "Use VS Code language features first, then fall back to Tree-sitter with a warning",
            "Use Tree-sitter queries first, then fall back to LSP with a warning"
          ],
          "description": "Choose how architecture diagrams are parsed. Auto prefers LSP and falls back when necessary."
        },
        "tldiagram.architecture.showParserWarnings": {
          "type": "boolean",
          "default": true,
          "description": "Show a warning when architecture generation falls back from the requested parser mode to another parser."
        },
        "tldiagram.architecture.callHierarchyDepth": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "maximum": 5,
          "description": "Call hierarchy traversal depth for relationship mapping. 0 disables call analysis entirely."
        },
        "tldiagram.architecture.groupingStrategy": {
          "type": "string",
          "default": "hybrid",
          "enum": [
            "folder",
            "role",
            "hybrid"
          ],
          "enumDescriptions": [
            "Group by directory structure",
            "Group by architectural role (API Layer, Services, Data Layer, etc.)",
            "Folder-first, falling back to role grouping for flat structures"
          ],
          "description": "How to cluster symbols into diagram groups."
        },
        "tldiagram.architecture.collapseIntermediates": {
          "type": "boolean",
          "default": true,
          "description": "Apply the Platonic filter: collapse pass-through nodes (single in, single out, no side effects) to simplify the graph."
        },
        "tldiagram.architecture.includeExternalLibraries": {
          "type": "boolean",
          "default": true,
          "description": "Create an 'External Dependencies' child diagram for detected third-party imports."
        },
        "tldiagram.architecture.includeUtilities": {
          "type": "boolean",
          "default": false,
          "description": "Include utility/helper classes in diagrams. Disable for cleaner high-level views."
        },
        "tldiagram.architecture.importRoleMap": {
          "type": "object",
          "default": {},
          "description": "Override or extend the default import-path → architectural role mapping. Keys are case-insensitive substrings matched against import paths (e.g. {\"my-db-lib\": \"repository\"}). An empty object uses the built-in defaults."
        },
        "tldiagram.architecture.customRolePatterns": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "pattern": {
                "type": "string",
                "description": "Regex or substring matched against the file path (case-insensitive)"
              },
              "role": {
                "type": "string",
                "enum": [
                  "api_entry",
                  "service",
                  "repository",
                  "data_exit",
                  "model",
                  "utility",
                  "external",
                  "unknown"
                ]
              }
            },
            "required": [
              "pattern",
              "role"
            ]
          },
          "default": [],
          "description": "Custom file-path pattern → architectural role overrides. These take highest priority, before tree-sitter queries and import analysis. Example: [{\"pattern\": \"/adapters/\", \"role\": \"repository\"}]"
        }
      }
    }
  },
  "scripts": {
    "compile:ext": "node esbuild.mjs",
    "compile:webview": "cd ../frontend && npm run build:vscode",
    "compile": "npm run compile:ext && npm run compile:webview",
    "watch": "node esbuild.mjs --watch",
    "package": "npm run compile && npx @vscode/vsce package",
    "vscode:prepublish": "npm run compile",
    "test": "vitest run",
    "arch:parse-local": "tsx src/parsing/treesitter/localArchitectureCli.ts"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.11.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-web": "^2.1.1",
    "@kreuzberg/tree-sitter-language-pack": "^1.4.1"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "esbuild": "^0.25.0",
    "glob": "^13.0.6",
    "module-alias": "^2.3.4",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  }
}
