{
  "name": "tldiagram",
  "displayName": "tlDiagram",
  "description": "Browse and edit tlDiagram architecture diagrams from VS Code",
  "version": "0.1.4",
  "publisher": "tlDiagram-com",
  "repository": "https://github.com/Mertcikla/tld-vsc-ext",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization"
  ],
  "tags": [
    "architecture",
    "diagram",
    "tlDiagram",
    "software design",
    "flow chart"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tldiagram",
          "title": "tlDiagram",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "tldiagram": [
        {
          "id": "tldiagram.diagramTree",
          "name": "Diagrams"
        },
        {
          "id": "tldiagram.elementLibrary",
          "name": "Element Library"
        },
        {
          "id": "tldiagram.watchDiff",
          "name": "Watch Changes",
          "when": "tldiagram.mode == local"
        }
      ]
    },
    "commands": [
      {
        "command": "tldiagram.refresh",
        "title": "tlDiagram: Refresh Diagrams",
        "icon": "$(refresh)"
      },
      {
        "command": "tldiagram.openDiagram",
        "title": "Open Diagram",
        "icon": "$(open-preview)"
      },
      {
        "command": "tldiagram.createDiagram",
        "title": "tlDiagram: New Diagram",
        "icon": "$(add)"
      },
      {
        "command": "tldiagram.renameDiagram",
        "title": "Rename Diagram"
      },
      {
        "command": "tldiagram.deleteDiagram",
        "title": "Delete Diagram",
        "icon": "$(trash)"
      },
      {
        "command": "tldiagram.openInBrowser",
        "title": "Open in Browser",
        "icon": "$(link-external)"
      },
      {
        "command": "tldiagram.addElementToDiagram",
        "title": "Add to Diagram",
        "icon": "$(add)"
      },
      {
        "command": "tldiagram.goToDiagram",
        "title": "Go to Diagram"
      },
      {
        "command": "tldiagram.showLogs",
        "title": "tlDiagram: Show Logs"
      },
      {
        "command": "tldiagram.analyzeFolder",
        "title": "tlDiagram: Analyze Folder",
        "icon": "$(search)"
      },
      {
        "command": "tldiagram.switchMode",
        "title": "tlDiagram: Reconnect Local CLI"
      },
      {
        "command": "tldiagram.startWatch",
        "title": "tlDiagram: Start Watching",
        "icon": "$(eye)"
      },
      {
        "command": "tldiagram.stopWatch",
        "title": "tlDiagram: Stop Watching",
        "icon": "$(circle-slash)"
      },
      {
        "command": "tldiagram.showWatchDiff",
        "title": "tlDiagram: Show Watch Changes",
        "icon": "$(diff)"
      },
      {
        "command": "tldiagram.watchQuickActions",
        "title": "tlDiagram: Watch Quick Actions"
      },
      {
        "command": "tldiagram.updateCli",
        "title": "tlDiagram: Install or Update CLI"
      },
      {
        "command": "tldiagram.installCli",
        "title": "tlDiagram: Install CLI"
      },
      {
        "command": "tldiagram.verifyCli",
        "title": "tlDiagram: Verify CLI"
      },
      {
        "command": "tldiagram.openDocs",
        "title": "tlDiagram: Open Documentation"
      },
      {
        "command": "tldiagram.focusDiagramsView",
        "title": "tlDiagram: Show Diagrams View"
      },
      {
        "command": "tldiagram.focusElementLibraryView",
        "title": "tlDiagram: Show Element Library"
      },
      {
        "command": "tldiagram.configureColors",
        "title": "tlDiagram: Configure UI Colors"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "tldiagram.focusDiagramsView",
          "when": "false"
        },
        {
          "command": "tldiagram.focusElementLibraryView",
          "when": "false"
        }
      ],
      "editor/context": [
        {
          "command": "tldiagram.goToDiagram",
          "when": "tldiagram.authenticated && tldiagram.mode == local",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "tldiagram.goToDiagram",
          "when": "tldiagram.authenticated && tldiagram.mode == local",
          "group": "navigation"
        },
        {
          "command": "tldiagram.analyzeFolder",
          "when": "explorerResourceIsFolder",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "tldiagram.refresh",
          "when": "view == tldiagram.diagramTree && tldiagram.authenticated",
          "group": "navigation"
        },
        {
          "command": "tldiagram.createDiagram",
          "when": "view == tldiagram.diagramTree && tldiagram.authenticated",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "tldiagram.openDiagram",
          "when": "viewItem == diagram",
          "group": "inline"
        },
        {
          "command": "tldiagram.openInBrowser",
          "when": "viewItem == diagram",
          "group": "inline"
        },
        {
          "command": "tldiagram.renameDiagram",
          "when": "viewItem == diagram",
          "group": "1_modify"
        },
        {
          "command": "tldiagram.deleteDiagram",
          "when": "viewItem == diagram",
          "group": "1_modify"
        },
        {
          "command": "tldiagram.addElementToDiagram",
          "when": "viewItem == diagElement",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "tlDiagram",
      "properties": {
        "tldiagram.mode": {
          "type": "string",
          "default": "local",
          "enum": [
            "local"
          ],
          "enumDescriptions": [
            "Use local mode through the tld CLI"
          ],
          "description": "Connection mode for the tlDiagram extension. The VS Code extension uses the local tld CLI."
        },
        "tldiagram.cliPath": {
          "type": "string",
          "default": "",
          "description": "Custom path to the tld binary (empty = auto-detect on PATH)"
        },
        "tldiagram.autoStartWatch": {
          "type": "boolean",
          "default": true,
          "description": "Automatically start tld watch when opening a workspace with .tld/ directory"
        },
        "tldiagram.watch.host": {
          "type": "string",
          "default": "127.0.0.1",
          "description": "Host for the local watch/serve server"
        },
        "tldiagram.watch.port": {
          "type": "integer",
          "default": 0,
          "description": "Port for the local watch/serve server (0 = auto-select free port)"
        },
        "tldiagram.uiColorMode": {
          "type": "string",
          "default": "vscodeTheme",
          "enum": [
            "vscodeTheme",
            "palette"
          ],
          "enumDescriptions": [
            "Import VS Code theme colors into tlDiagram accent, canvas, and element colors",
            "Use the tlDiagram palette values configured below"
          ],
          "description": "Controls how tlDiagram chooses UI colors inside VS Code webviews."
        },
        "tldiagram.paletteAccent": {
          "type": "string",
          "default": "#63b3ed",
          "pattern": "^#[0-9a-fA-F]{6}$",
          "description": "Accent color used when tlDiagram UI color mode is set to palette."
        },
        "tldiagram.paletteCanvas": {
          "type": "string",
          "default": "#10151f",
          "pattern": "^#[0-9a-fA-F]{6}$",
          "description": "Canvas color used when tlDiagram UI color mode is set to palette."
        },
        "tldiagram.paletteElement": {
          "type": "string",
          "default": "#1f2937",
          "pattern": "^#[0-9a-fA-F]{6}$",
          "description": "Element color used when tlDiagram UI color mode is set to palette."
        },
        "tldiagram.logLevel": {
          "type": "string",
          "default": "info",
          "enum": [
            "off",
            "error",
            "warn",
            "info",
            "debug",
            "trace"
          ],
          "enumDescriptions": [
            "No logging",
            "Errors only",
            "Errors and warnings",
            "Normal operational messages (default)",
            "Verbose: includes API calls, panel lifecycle, tree view updates",
            "Very verbose: includes every message routed through the bridge and every object created"
          ],
          "description": "Controls verbosity of the tlDiagram output channel. Use 'debug' or 'trace' when reporting issues."
        }
      }
    },
    "walkthroughs": [
      {
        "id": "tldiagram.getStarted",
        "title": "Get Started with tlDiagram",
        "description": "Live architecture diagrams that stay in sync with your code.",
        "steps": [
          {
            "id": "tldiagram.welcome",
            "title": "Welcome to tlDiagram",
            "description": "tlDiagram keeps your architecture diagrams in sync with your codebase. Install the CLI to get started.",
            "media": {
              "image": "resources/walkthrough/tld.svg",
              "altText": "tlDiagram logo"
            }
          },
          {
            "id": "tldiagram.installCli",
            "title": "Install the tld CLI",
            "description": "The CLI is required for local diagram workflows. Source: [github.com/Mertcikla/tld](https://github.com/Mertcikla/tld).\n\n[Install CLI](command:tldiagram.installCli)",
            "media": {
              "markdown": "resources/walkthrough/install-cli.md"
            },
            "completionEvents": [
              "onCommand:tldiagram.verifyCli"
            ]
          },
          {
            "id": "tldiagram.authoringWorkflows",
            "title": "Choose a workflow",
            "description": "**Manual** — run `tld serve`, edit diagrams in the browser.\n\n**Analyze** — run `tld analyze` once to index your codebase and enable code↔diagram links.\n\n**Watch** — run `tld watch` for continuous sync as you code.\n\n[Open docs](command:tldiagram.openDocs)",
            "media": {
              "markdown": "resources/walkthrough/workflows.md"
            }
          },
          {
            "id": "tldiagram.sidebarViews",
            "title": "Diagrams and Element Library",
            "description": "Click the tlDiagram icon in the activity bar to browse diagrams and pick elements from the library.\n\n[Show Diagrams](command:tldiagram.focusDiagramsView) [Show Element Library](command:tldiagram.focusElementLibraryView)",
            "media": {
              "markdown": "resources/walkthrough/sidebar.md"
            }
          },
          {
            "id": "tldiagram.sourceLinks",
            "title": "Jump between code and diagrams",
            "description": "Right-click a file or symbol → **Go to Diagram** to open the linked diagram. Inside a diagram, click **Open in Editor** to jump back to source.",
            "media": {
              "markdown": "resources/walkthrough/source-links.md"
            }
          },
          {
            "id": "tldiagram.colors",
            "title": "Customize colors",
            "description": "tlDiagram automatically inherits your VS Code theme colors. Switch to a custom palette anytime in settings.\n\n[Configure colors](command:tldiagram.configureColors)",
            "media": {
              "markdown": "resources/walkthrough/colors.md"
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "compile:ext": "node esbuild.mjs",
    "compile:webview": "cd ../tld/frontend && npm run build:vscode",
    "compile": "npm run compile:ext && npm run compile:webview",
    "watch": "node esbuild.mjs --watch",
    "package": "npm run compile && npx @vscode/vsce package",
    "vscode:prepublish": "npm run compile",
    "test": "vitest run"
  },
  "dependencies": {
    "@buf/tldiagramcom_diagram.bufbuild_es": "^2.12.0-20260510134954-1dd1981cf3f6.1",
    "@bufbuild/protobuf": "^2.11.0",
    "@connectrpc/connect": "^2.1.1",
    "@connectrpc/connect-web": "^2.1.1"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "esbuild": "^0.25.0",
    "glob": "^13.0.6",
    "module-alias": "^2.3.4",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.9"
  }
}
